# PostgreSQL connection string for Prisma
# Example (Neon/Supabase/Railway):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
DATABASE_URL="postgresql://user:password@host:5432/dashboard_gcg?sslmode=require"

# iron-session secret (min 32 chars)
SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
