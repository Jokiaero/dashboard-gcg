generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DataLaporan {
  id               Int       @id @default(autoincrement())
  tahun            String?
  pers_no          String?
  nik              String?
  nama             String?
  jabatan          String?
  ou               String?
  file             String?
  status_approved  String?
  site             String?
  approved_by      String?
  approved_date    DateTime?
  updated_by       String?
  updated_date     DateTime?
  generated_by     String?
  generated_date   DateTime?
  sign_loc         String?
  kode_jabatan     String?
  jabatan_lengkap  String?
  dept_id          String?
  department       String?
  div_id           String?
  divisi           String?
  direktorat_id    String?
  direktorat       String?
  work_contract_id String?
  work_contract    String?
  createdAt        DateTime  @default(now())

  @@map("data_laporan")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  role         String   @default("USER") // ADMIN, USER, USER_VIP
  profileImage String?  @map("profile_image")
  createdAt    DateTime @default(now())

  @@map("users")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String   // e.g. "CREATE_LAPORAN"
  username  String   // who did it
  details   String?  // e.g. "Added laporan WBS Kiln"
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model DashboardSettings {
  id               Int      @id
  dashboardTitle   String   @map("dashboard_title")
  dashboardSubtitle String  @map("dashboard_subtitle")
  kajian2025       String   @map("kajian_2025")
  kajian2024       String   @map("kajian_2024")
  isoNote          String   @map("iso_note")
  penghargaanNote  String   @map("penghargaan_note")
  penghargaanUrl   String?  @map("penghargaan_url")
  regulasiOrder    String?  @map("regulasi_order")
  softstructureOrder String? @map("softstructure_order")
  kajianOrder      String?  @map("kajian_order")
  gcgScoresJson    String   @map("gcg_scores_json")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("dashboard_settings")
}

model UploadedDocument {
  id           BigInt    @id @default(autoincrement())
  category     String
  name         String
  originalName String?   @map("original_name")
  url          String
  thumbnailUrl String?   @map("thumbnail_url")
  size         BigInt    @default(0)
  mimeType     String?   @map("mime_type")
  uploadedBy   String?   @map("uploaded_by")
  regulasiSlug String?   @map("regulasi_slug")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@unique([category, name])
  @@index([category, isDeleted, updatedAt])
  @@map("uploaded_documents")
}

model UploadedDocumentRecycle {
  id           BigInt   @id @default(autoincrement())
  category     String
  name         String
  originalName String?  @map("original_name")
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  size         BigInt   @default(0)
  mimeType     String?  @map("mime_type")
  uploadedBy   String?  @map("uploaded_by")
  regulasiSlug String?  @map("regulasi_slug")
  deletedAt    DateTime @default(now()) @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([category, name])
  @@index([category, deletedAt])
  @@map("uploaded_documents_recycle")
}
